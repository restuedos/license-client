{
    "name": "edzero/license-client",
    "description": "License client package for EDZero applications.",
    "readme": "README.md",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "ext-openssl": "*",
        "illuminate/console": "^13.0",
        "illuminate/contracts": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/support": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Edzero\\LicenseClient\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Edzero\\LicenseClient\\LicenseClientServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
